# wow-server .env — copy to .env and edit before running any script.
# All paths are on the NixOS host.

# Workspace root — all server data lives here.
WOW_ROOT=/data/wow

# Volume bind paths (must exist before running scripts).
DOCKER_VOL_ETC=/data/wow/configs
DOCKER_VOL_LOGS=/data/wow/logs
DOCKER_VOL_DATA=/data/wow/data
DOCKER_VOL_ROOT=/data/wow/server/ac

# Container build args — align with your host user.
DOCKER_USER=acore
DOCKER_USER_ID=1000
DOCKER_GROUP_ID=1000
DOCKER_IMAGE_TAG=local

# Ports — bind to 0.0.0.0 so LAN clients (Mac, etc.) can reach the server.
# Change to 127.0.0.1 if you only want local access.
DOCKER_AUTH_EXTERNAL_PORT=3724
DOCKER_WORLD_EXTERNAL_PORT=8085
DOCKER_SOAP_EXTERNAL_PORT=7878
DOCKER_DB_EXTERNAL_PORT=3306

# Database password (server is LAN-only, not exposed to internet).
DOCKER_DB_ROOT_PASSWORD=acorewotlk

# Realm address — set to your server's LAN IP so clients can connect.
REALM_ADDRESS=192.168.1.6

# Backup retention (days).
KEEP_DAILY=14
KEEP_WEEKLY=8

# Account defaults for setup-all.sh (override via env or --args).
ACCT_USER=admin
ACCT_PASS=changeme
ACCT_GM=3
